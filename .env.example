# Withings application credentials (https://developer.withings.com).
# Used only by the runnable examples in examples/ — the library itself reads no
# environment variables. Copy this file to `.env` and fill in your values.
WITHINGS_CLIENT_ID=your-withings-client-id
WITHINGS_CLIENT_SECRET=your-withings-client-secret
WITHINGS_CALLBACK_URL=http://localhost:3000/callback
